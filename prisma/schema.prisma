generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  phone     String?  @unique
  avatar    String?
  avatarPublicId String?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auth                 Auth?
  oauthAccounts        OAuthAccount[]
  addresses            Address[]
  orders               Order[]
  reviews              Review[]
  wishlist             Wishlist[]
  orderStatusHistories OrderStatusHistory[]
}

model OAuthAccount {
  id         String   @id @default(uuid())
  provider   AuthProvider
  providerId String
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
}

model Auth {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String?
  role       Role     @default(CUSTOMER)
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Address {
  id         String   @id @default(uuid())
  userId     String
  fullName   String
  email      String
  phone      String
  street     String
  city       String
  state      String?
  postalCode String
  country    String
  isDefault  Boolean @default(false)  
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User    @relation(fields: [userId], references: [id])
  order Order[]

  @@index([userId])
}

model SizeGroup {
  id        String  @id @default(uuid())
  name      String  @unique
  isDeleted Boolean @default(false)

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  sizes      Size[]
  categories Category[]
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  logo      String?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Size {
  id          String           @id @default(uuid())
  name        String           
  sizeGroupId String           
  sizeGroup   SizeGroup?       @relation(fields: [sizeGroupId], references: [id], onDelete: SetNull)
  isDeleted   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  variants    ProductVariant[]

  @@index([name])
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  parentId    String?
  sizeGroupId String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent    Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryParent")
  sizeGroup SizeGroup? @relation(fields: [sizeGroupId], references: [id])
  products  Product[]

  @@index([slug])
}

model Product {
  id            String   @id @default(uuid())
  name          String   @unique
  slug          String   @unique
  description   String
  basePrice     Decimal  @db.Decimal(10, 2)
  discountPrice Decimal? @db.Decimal(10, 2)
  stockQuantity Int      @default(0)
  isPublished   Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  gender        Gender
  categoryId    String
  brandId       String
  averageRating Decimal? @db.Decimal(3, 2) // Changed from Int to Decimal for precision
  totalReviews  Int      @default(0)
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  brand         Brand            @relation(fields: [brandId], references: [id])
  category      Category         @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems Wishlist[]

  @@index([categoryId])
  @@index([brandId])
  @@index([slug])
  @@index([isPublished])
  @@index([isFeatured])
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  sizeId    String?
  color     String
  stock     Int      @default(0)
  price     Decimal  @default(0) @db.Decimal(10, 2)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  size       Size?       @relation(fields: [sizeId], references: [id])

  @@index([productId])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  publicId  String
  altText   String?
  isMain    Boolean @default(false)
  isDeleted Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // Prevent duplicates
  @@index([userId])
}

model Review {
  id        String   @id @default(uuid())
  rating    Decimal  @db.Decimal(10, 2) // 1-5
  comment   String?
  userId    String
  productId String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([rating])
}

model Order {
  id                String        @id @default(uuid())
  orderNumber       String        @unique // e.g., "ORD-2024-001234"
  userId            String
  subtotal          Decimal       @default(0) @db.Decimal(10, 2) // Sum of all items before tax and shipping
  tax               Decimal       @default(0) @db.Decimal(10, 2) // Calculated tax amount
  shippingCost      Decimal       @default(0) @db.Decimal(10, 2) // Shipping fee (0 if free shipping)
  discount          Decimal       @default(0) @db.Decimal(10, 2) // Total discount on all items
  totalAmount       Decimal       @db.Decimal(10, 2) // subtotal + tax + shippingCost
  paymentStatus     PaymentStatus @default(PENDING)
  paymentMethod     PaymentMethod
  orderStatus       OrderStatus   @default(PENDING)
  shippingAddressId String
  ipAddress         String?
  userAgent         String?
  notes             String?
  shippingSnapshot  Json? // Store full address snapshot at time of order
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  shippingAddress Address              @relation(fields: [shippingAddressId], references: [id], onDelete: SetNull)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  payment         Payment?
  statusHistory   OrderStatusHistory[]

  @@index([userId])
  @@index([orderNumber])
  @@index([paymentStatus])
  @@index([orderStatus])
  @@index([createdAt])
}

model OrderItem {
  id              String          @id @default(uuid())
  orderId         String
  productId       String
  productName     String
  variantId       String?
  variantDetails  String? // e.g., "Red, Size M" - for reference
  quantity        Int             @db.SmallInt
  priceAtPurchase Decimal         @default(0) @db.Decimal(10, 2) // Actual price paid (with variant modifiers)
  originalPrice   Decimal         @default(0) @db.Decimal(10, 2) // Price before any discount
  discount        Decimal         @default(0) @db.Decimal(10, 2) // (originalPrice - priceAtPurchase) * quantity
  subtotal        Decimal         @default(0) @db.Decimal(10, 2) // priceAtPurchase * quantity
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id])
  variant         ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id              String        @id @default(uuid())
  orderId         String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  transactionId   String?       @unique
  paymentGateway  String? // "stripe", "paypal", etc.
  gatewayResponse Json? // Full response from payment gateway
  failureReason   String?
  paidAt          DateTime?
  refundedAt      DateTime?
  refundAmount    Decimal?      @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([transactionId])
  @@index([status])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  oldStatus OrderStatus
  newStatus OrderStatus
  ipAddress String?
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model Slide {
  id        String   @id @default(uuid())
  title     String   @unique
  subtitle  String
  photoUrl  String
  url       String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  CASH_ON_DELIVERY
}

enum Gender {
  MEN
  WOMEN
  KIDS
  UNISEX
}

enum AuthProvider {
  EMAIL
  GOOGLE
  FACEBOOK
}
